<ui:FluentWindow x:Class="PasskeyAutofill.App.MainWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 Title="Passkey Autofill"
                 Width="920" Height="660"
                 MinWidth="760" MinHeight="560"
                 WindowStartupLocation="CenterScreen"
                 ExtendsContentIntoTitleBar="True"
                 WindowBackdropType="Mica">

    <Grid>
        <Grid.Resources>
            <!-- Passive info hint: not a button — nothing to click, no focus stop.
                 Help cursor + near-instant tooltip that stays up long enough to read. -->
            <Style x:Key="InfoHint" TargetType="ui:SymbolIcon">
                <Setter Property="Symbol" Value="Info24" />
                <Setter Property="FontSize" Value="14" />
                <Setter Property="Foreground" Value="#666666" />
                <Setter Property="Cursor" Value="Help" />
                <Setter Property="Margin" Value="8,0,0,0" />
                <Setter Property="VerticalAlignment" Value="Center" />
                <Setter Property="ToolTipService.InitialShowDelay" Value="100" />
                <Setter Property="ToolTipService.ShowDuration" Value="20000" />
            </Style>
        </Grid.Resources>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="Passkey Autofill" />

        <!-- BODY: state-driven panel (left) + device identity (right) -->
        <Grid Grid.Row="1" Margin="24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="340" />
            </Grid.ColumnDefinitions>

            <!-- LEFT: one panel per screen state (Screen drives visibility) -->
            <Border Grid.Column="0" Margin="0,0,16,0" Padding="24"
                    CornerRadius="8" Background="#1E1E1E">
                <StackPanel MaxWidth="460" HorizontalAlignment="Left">

                    <!-- DISCONNECTED -->
                    <TextBlock Foreground="#CCCCCC"
                               Visibility="{Binding Screen, Converter={StaticResource VisibleWhen}, ConverterParameter=Disconnected}"
                               Text="Insert your security key." />

                    <!-- BUSY -->
                    <StackPanel Orientation="Horizontal"
                                Visibility="{Binding Screen, Converter={StaticResource VisibleWhen}, ConverterParameter=Busy}">
                        <ui:ProgressRing IsIndeterminate="True" Width="20" Height="20" />
                        <TextBlock Foreground="#999999" Margin="10,0,0,0" VerticalAlignment="Center"
                                   Text="{Binding BusyText}" />
                    </StackPanel>

                    <!-- LOCKED: inline PIN entry, no dialog -->
                    <StackPanel Visibility="{Binding Screen, Converter={StaticResource VisibleWhen}, ConverterParameter=Locked}">
                        <TextBlock Foreground="#CCCCCC" TextWrapping="Wrap"
                                   Text="{Binding Message}" />

                        <ui:PasswordBox Margin="0,16,0,0"
                                        PlaceholderText="PIN"
                                        Password="{Binding Pin, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                            <ui:PasswordBox.InputBindings>
                                <KeyBinding Key="Return" Command="{Binding UnlockCommand}" />
                            </ui:PasswordBox.InputBindings>
                        </ui:PasswordBox>

                        <!-- Retry / low-count status: red after a wrong PIN, amber advisory
                             when ≤ 3 tries remain (shown before any attempt, like the
                             Authenticator). -->
                        <TextBlock FontSize="12" TextWrapping="Wrap" Margin="0,6,0,0"
                                   Text="{Binding PinStatus}"
                                   Visibility="{Binding HasPinStatus, Converter={StaticResource BoolToVisibility}}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#E0B050" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding PinStatusIsError}" Value="True">
                                            <Setter Property="Foreground" Value="#FF4444" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <!-- Opt-in persistence of the read-only token (PPUAT) -->
                        <CheckBox Margin="0,12,0,0"
                                  IsChecked="{Binding PersistChoice}"
                                  Content="Keep read-only access on this PC" />

                        <ui:Button Content="Unlock" Appearance="Primary" Margin="0,16,0,0"
                                   Command="{Binding UnlockCommand}" />
                    </StackPanel>

                    <!-- UNLOCKED: passkey list + forget -->
                    <StackPanel Visibility="{Binding Screen, Converter={StaticResource VisibleWhen}, ConverterParameter=Unlocked}">

                        <!-- One row per passkey: account (primary), RP id (secondary), payment badge -->
                        <ListView ItemsSource="{Binding Passkeys}" MaxHeight="280"
                                  Background="Transparent" BorderThickness="0"
                                  ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                    <Setter Property="Padding" Value="12,10" />
                                </Style>
                            </ListView.ItemContainerStyle>
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock FontWeight="SemiBold" Foreground="White"
                                                           Text="{Binding AccountName}" />
                                                <Border Margin="8,0,0,0" Padding="5,1" CornerRadius="3"
                                                        Background="#332B12" VerticalAlignment="Center"
                                                        Visibility="{Binding ThirdPartyPayment, Converter={StaticResource BoolToVisibility}}">
                                                    <TextBlock Foreground="#E0B050" FontSize="10" Text="payment" />
                                                </Border>
                                            </StackPanel>
                                            <TextBlock FontSize="11" Foreground="#999999"
                                                       Text="{Binding RelyingPartyId}" />
                                        </StackPanel>
                                        <ui:Button Grid.Column="1" Content="Sign in" Margin="12,0,0,0"
                                                   VerticalAlignment="Center"
                                                   Command="{Binding DataContext.SignInCommand, RelativeSource={RelativeSource AncestorType=ListView}}"
                                                   CommandParameter="{Binding}" />
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>

                        <TextBlock Foreground="#666666" FontSize="11" Margin="0,8,0,0"
                                   Text="Sign in runs a real assertion. Touch the key when it blinks." />

                        <!-- Footnote: used vs. capacity + a chip explaining whether the key
                             was re-queried (amber) or the cached list was used (green). -->
                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                            <TextBlock Foreground="#999999" FontSize="11"
                                       Text="{Binding PasskeyCountText}" />
                            <TextBlock Margin="8,0,0,0" FontSize="11" VerticalAlignment="Center"
                                       Text="{Binding CacheStatus}"
                                       Visibility="{Binding HasCacheStatus, Converter={StaticResource BoolToVisibility}}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#E0B050" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsCacheHit}" Value="True">
                                                <Setter Property="Foreground" Value="#3FB950" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>

                        <!-- Forget this PC: erases the persisted PPUAT -->
                        <StackPanel Orientation="Horizontal" Margin="0,32,0,0"
                                    Visibility="{Binding CanForgetPc, Converter={StaticResource BoolToVisibility}}">
                            <ui:Button Content="Forget this PC" Appearance="Secondary"
                                       Command="{Binding ForgetPcCommand}" />
                            <ui:SymbolIcon Style="{StaticResource InfoHint}">
                                <ui:SymbolIcon.ToolTip>
                                    <TextBlock MaxWidth="260" TextWrapping="Wrap"
                                               Text="A read-only token is saved on this PC so you don't need your PIN again. Remove it to require PIN on the next unlock." />
                                </ui:SymbolIcon.ToolTip>
                            </ui:SymbolIcon>
                        </StackPanel>
                    </StackPanel>

                    <!-- SIGNED IN -->
                    <StackPanel Visibility="{Binding Screen, Converter={StaticResource VisibleWhen}, ConverterParameter=SignedIn}">
                        <TextBlock FontSize="16" FontWeight="SemiBold" Foreground="White"
                                   Text="Signed in" />
                        <TextBlock Foreground="#999999" TextWrapping="Wrap" Margin="0,6,0,0"
                                   Text="{Binding Message}" />
                        <ui:Button Content="Back to passkeys" Margin="0,16,0,0"
                                   Command="{Binding BackCommand}" />
                    </StackPanel>

                    <!-- EMPTY -->
                    <StackPanel Visibility="{Binding Screen, Converter={StaticResource VisibleWhen}, ConverterParameter=Empty}">
                        <TextBlock Foreground="#CCCCCC" TextWrapping="Wrap"
                                   Text="This security key has no passkeys." />
                        <StackPanel Orientation="Horizontal" Margin="0,20,0,0"
                                    Visibility="{Binding CanForgetPc, Converter={StaticResource BoolToVisibility}}">
                            <ui:Button Content="Forget this PC" Appearance="Secondary"
                                       Command="{Binding ForgetPcCommand}" />
                            <ui:SymbolIcon Style="{StaticResource InfoHint}">
                                <ui:SymbolIcon.ToolTip>
                                    <TextBlock MaxWidth="260" TextWrapping="Wrap"
                                               Text="A read-only token is saved on this PC so you don't need your PIN again. Remove it to require PIN on the next unlock." />
                                </ui:SymbolIcon.ToolTip>
                            </ui:SymbolIcon>
                        </StackPanel>
                    </StackPanel>

                    <!-- UNSUPPORTED: retry covers swapping in a 5.8 key -->
                    <StackPanel Visibility="{Binding Screen, Converter={StaticResource VisibleWhen}, ConverterParameter=Unsupported}">
                        <TextBlock Foreground="#CCCCCC" TextWrapping="Wrap"
                                   Text="{Binding Message}" />
                        <ui:Button Content="Check again" Margin="0,16,0,0"
                                   Command="{Binding RetryCommand}" />
                    </StackPanel>

                    <!-- ERROR -->
                    <StackPanel Visibility="{Binding Screen, Converter={StaticResource VisibleWhen}, ConverterParameter=Error}">
                        <TextBlock Foreground="#CCCCCC" TextWrapping="Wrap"
                                   Text="{Binding Message}" />
                        <ui:Button Content="Try again" Margin="0,16,0,0"
                                   Command="{Binding RetryCommand}" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- RIGHT: key details, a plain grid of label-value rows -->
            <Border Grid.Column="1" Padding="20" CornerRadius="8" Background="#1E1E1E">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock FontSize="14" FontWeight="SemiBold" Foreground="White"
                                   Text="Key details" />

                        <TextBlock Foreground="#666666" FontSize="12" TextWrapping="Wrap" Margin="0,12,0,0"
                                   Visibility="{Binding HasIdentity, Converter={StaticResource BoolToVisibility}, ConverterParameter=Invert}"
                                   Text="Unlock the key to read its details." />

                        <Grid Margin="0,12,0,0"
                              Visibility="{Binding HasIdentity, Converter={StaticResource BoolToVisibility}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Foreground="#999999" FontSize="11"
                                       Margin="0,0,12,8" Text="Firmware" />
                            <TextBlock Grid.Row="0" Grid.Column="1" Foreground="White" FontSize="12"
                                       Margin="0,0,0,8" Text="{Binding FirmwareVersion}" />

                            <TextBlock Grid.Row="1" Grid.Column="0" Foreground="#999999" FontSize="11"
                                       Margin="0,0,12,8" Text="Device ID (encIdentifier)" />
                            <TextBlock Grid.Row="1" Grid.Column="1" Foreground="White" FontSize="12"
                                       FontFamily="Consolas" TextWrapping="Wrap"
                                       Margin="0,0,0,8" Text="{Binding DeviceId}" />

                            <TextBlock Grid.Row="2" Grid.Column="0" Foreground="#999999" FontSize="11"
                                       Margin="0,0,12,8" Text="Store state (encCredStoreState)" />
                            <TextBlock Grid.Row="2" Grid.Column="1" Foreground="White" FontSize="12"
                                       FontFamily="Consolas" TextWrapping="Wrap"
                                       Margin="0,0,0,8" Text="{Binding CredStoreState}" />

                            <TextBlock Grid.Row="3" Grid.Column="0" Foreground="#999999" FontSize="11"
                                       Margin="0,0,12,0" Text="thirdPartyPayment" />
                            <TextBlock Grid.Row="3" Grid.Column="1" Foreground="White" FontSize="12"
                                       Text="{Binding ThirdPartyPaymentText}" />
                        </Grid>

                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</ui:FluentWindow>
